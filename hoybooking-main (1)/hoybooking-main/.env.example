HOYBOOKING_SECRET_KEY=dev-secret-change-me

# Local default is SQLite (no MySQL required).
# To force MySQL, set:
# HOYBOOKING_DB_BACKEND=mysql
# or HOYBOOKING_USE_MYSQL=true

# MySQL connection settings
HOYBOOKING_DB_HOST=127.0.0.1
HOYBOOKING_DB_PORT=3307
HOYBOOKING_DB_USER=root
HOYBOOKING_DB_PASSWORD=PUT_YOUR_MYSQL_PASSWORD_HERE
HOYBOOKING_DB_NAME=hoybooking
HOYBOOKING_DB_CHARSET=utf8mb4

# Optional admin bootstrap (recommended for deployment)
# HOYBOOKING_ADMIN_EMAIL=admin@example.com
# HOYBOOKING_ADMIN_PASSWORD=ChangeMe123
# HOYBOOKING_ADMIN_NAME=Main Admin
# HOYBOOKING_ADMIN_RESET_ON_START=false

